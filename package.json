{
  "name": "copy-file-path-with-range",
  "displayName": "Copy File Path with Range",
  "description": "Copy file path with range to provide as context to coding assistants",
  "publisher": "drisspg",
  "version": "1.0.3",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/drisspg/copy-file-path-with-range"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copy-file-path-with-range.copyRelativePath",
        "title": "Copy Relative Path with Range"
      },
      {
        "command": "copy-file-path-with-range.copyAbsolutePath",
        "title": "Copy Absolute Path with Range"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "copy-file-path-with-range.copyRelativePath",
          "group": "9_cutcopypaste",
          "when": "editorTextFocus"
        },
        {
          "command": "copy-file-path-with-range.copyAbsolutePath",
          "group": "9_cutcopypaste",
          "when": "editorTextFocus"
        }
      ]
    },
    "keybindings": [
      {
        "command": "copy-file-path-with-range.copyRelativePath",
        "key": "alt+l",
        "mac": "alt+l",
        "when": "editorTextFocus"
      },
      {
        "command": "copy-file-path-with-range.copyAbsolutePath",
        "key": "alt+shift+l",
        "mac": "alt+shift+l",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "dev": "pnpm run lint-and-type-check && node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "pnpm run lint-and-type-check && node esbuild.js --production",
    "package": "pnpm vsce package",
    "lint-and-type-check": "pnpm run check-types && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vscode:prepublish": "pnpm run build",
    "convert-icon": "node convert-icon.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "npm-run-all": "^4.1.5",
    "sharp": "^0.34.3",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
